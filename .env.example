# ── Supabase ────────────────────────────────────────────────────────────────
# Local dev: values printed by `supabase start` / `supabase status`.
# Production: from the Supabase dashboard (API settings).
NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
# Service-role/secret key — server only, never expose to the browser.
SUPABASE_SECRET_KEY=

# ── Stripe ──────────────────────────────────────────────────────────────────
# Leave STRIPE_SECRET_KEY empty until the Stripe account exists: the app then
# runs in TEST BYPASS mode (simulated checkout, credits granted instantly and
# flagged as test transactions). Set all three to go live.
STRIPE_SECRET_KEY=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=
# Safety gate: test bypass refuses to run on a production deployment
# (VERCEL_ENV=production) unless this is explicitly set to 1.
PAYMENTS_ALLOW_TEST_BYPASS=

# ── Jobs ────────────────────────────────────────────────────────────────────
# Shared secret protecting the compliance-reminder cron route
# (/api/cron/compliance). Vercel Cron sends it as a Bearer token.
CRON_SECRET=
